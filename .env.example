# Server Configuration
PORT=3000
NODE_ENV=development

# MyAnimeList API (for reading public lists)
# Get from: https://myanimelist.net/apiconfig
MAL_CLIENT_ID=

# AniList OAuth (for progress updates)
# Register app at: https://anilist.co/settings/developer
# Redirect URI: http://your-domain.com/auth/anilist/YOUR_USERNAME/callback
ANILIST_CLIENT_ID=
ANILIST_CLIENT_SECRET=

# MyAnimeList OAuth (for progress updates)
# Register app at: https://myanimelist.net/apiconfig
# Redirect URI: http://your-domain.com/auth/mal/YOUR_USERNAME/callback
MAL_OAUTH_CLIENT_ID=
MAL_OAUTH_CLIENT_SECRET=
