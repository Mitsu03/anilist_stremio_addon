# Server Configuration
PORT=3000
NODE_ENV=development

# MyAnimeList API (for reading public lists)
# Get from: https://myanimelist.net/apiconfig
MAL_CLIENT_ID=

# AniList OAuth (for progress updates)
# Register app at: https://anilist.co/settings/developer
# Redirect URI: http://your-domain.com/auth/anilist/callback
ANILIST_CLIENT_ID=
ANILIST_CLIENT_SECRET=

# MyAnimeList OAuth (for progress updates)
# Register app at: https://myanimelist.net/apiconfig
# Redirect URI: http://your-domain.com/auth/mal/callback
MAL_CLIENT_SECRET=

# Letterboxd OAuth (for watchlist sync)
# Token URL: https://api.letterboxd.com/api/v0/auth/token
LETTERBOXD_CLIENT_ID=
LETTERBOXD_CLIENT_SECRET=
LETTERBOXD_GRANT_TYPE=client_credentials
