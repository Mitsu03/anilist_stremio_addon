{
  "name": "anilist-stremio",
  "version": "1.7.0",
  "description": "Stremio extension to sync AniList currently watching anime to library",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": [
      "services/**/*.js",
      "config/tokens.js"
    ]
  },
  "keywords": [
    "stremio",
    "anilist",
    "anime"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.0.1"
  }
}
